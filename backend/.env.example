# Application
APP_NAME=Hata
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=production

# Server
HOST=0.0.0.0
PORT=8000
FRONTEND_URL=http://localhost:5173

# Database
DATABASE_URL=postgresql+asyncpg://hata:hata@localhost:5432/hata
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Security (CHANGE IN PRODUCTION!)
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
REFRESH_TOKEN_EXPIRE_DAYS=30

# CORS (comma-separated for multiple origins)
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Parser Settings
PARSER_BASE_URL=https://eri2.nca.by
PARSER_DELAY_MIN=1.0
PARSER_DELAY_MAX=3.0
PARSER_TIMEOUT=30000
PARSER_MAX_RETRIES=3
PARSER_CONCURRENT_PAGES=2

# Proxy Settings (optional)
PARSER_PROXY_ENABLED=false
PARSER_PROXY_URL=
PARSER_PROXY_LIST=[]

# Storage
STORAGE_PATH=./storage
PHOTOS_PATH=./storage/photos
LOGS_PATH=./storage/logs

# Map Settings
MAP_DEFAULT_LAT=53.9
MAP_DEFAULT_LNG=27.5667
MAP_DEFAULT_ZOOM=7
